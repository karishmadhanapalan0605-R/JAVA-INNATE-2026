import java.util.*;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter the string:");
        String str = sc.nextLine();
        int[] counts = new int[256];
        for (int i = 0; i < str.length(); i++) {
            char ch = str.charAt(i);
            counts[ch]++;
            if (counts[ch] == 2) {
                continue;
            }
            System.out.print(ch);
        }
    }
}
