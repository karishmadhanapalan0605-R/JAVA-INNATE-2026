class Main {
    public static void main(String[] args) {
        System.out.println("Even Odd");
        for (int i = 0; i <= 100; i += 2) {
            int even = i;
            int odd = i + 1;
            if (odd <= 100) {
                System.out.println(even + " " + odd);
        } else {
            System.out.println(even);
        }
    }
    }
}
