//toArray()
import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");

        // Convert to a regular String array
        String[] normalArray = list.toArray(new String[0]);
        
