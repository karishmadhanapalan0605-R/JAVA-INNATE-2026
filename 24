//removeRange()
import java.util.ArrayList;

class MyList extends ArrayList<String> {
    public void clearRange(int start, int end) {
        this.removeRange(start, end); // Unlocks the protected method
    }
}

public class Main {
    public static void main(String[] args) {
        MyList list = new MyList();
        list.add("0"); list.add("1"); list.add("2"); list.add("3");

        list.clearRange(1, 3); // Deletes index 1 and 2
        System.out.println(list); // [0, 3]
    }
}
