//trimToSize()
import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {
        // Creates a list with a hidden internal storage buffer of 50 spaces
        ArrayList<String> list = new ArrayList<>(50); 
        list.add("Apple");
        list.add("Banana");

        // Trims the hidden storage capacity from 50 spaces down to exactly 2 spaces
        list.trimToSize(); 
        
        System.out.println(list); // [Apple, Banana]
    }
}
