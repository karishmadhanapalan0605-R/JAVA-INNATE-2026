//removeIf()
import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple");
        list.add("Banana");
        list.add("Apricot");

        // Removes any fruit that starts with the letter "A"
        list.removeIf(fruit -> fruit.startsWith("A"));
        
        System.out.println(list); // [Banana]
    }
}
