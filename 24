//removeAll()
import java.util.ArrayList;

public class Main {
    public static void main(String[] args) {
        ArrayList<String> list = new ArrayList<>();
        list.add("Apple"); list.add("Banana"); list.add("Cherry");

        ArrayList<String> trash = new ArrayList<>();
        trash.add("Apple");
        trash.add("Cherry");

        list.removeAll(trash); // Deletes both Apple and Cherry
        System.out.println(list); // [Banana]
    }
}
