public class Main {
    public static void main(String[] args) {
        int[][] matrix = {{1,2,3},{4,5,6},{7,8,9}};
        int total = 0;
        for (int[] row:matrix) {
            for (int value:row) {
                total += value;
            }
        }
        int result = total - matrix[1][1];
        System.out.println(result);
    }
}
